# GKG capture daemon - environment file template
# ---------------------------------------------
# Copy this file to .env beside gkg-capture.ahk on Corazon and fill in
# GKG_DAEMON_HMAC_SECRET. The secret lives in Supabase kv_store at
# `gkg.daemon_hmac_secret`. Probe with:
#
#   POST https://api.admin.ecodia.au/api/admin/kv (admin auth) OR via
#   supabase MCP: db_query SELECT value FROM kv_store WHERE key = 'gkg.daemon_hmac_secret'
#
# .env is gitignored. Never commit a populated copy.

GKG_DAEMON_HMAC_SECRET=REPLACE_ME_WITH_KV_STORE_VALUE
